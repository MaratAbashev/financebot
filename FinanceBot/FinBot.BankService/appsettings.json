{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "Observability": {
    "ServiceName": "finbot.bankservice",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://otel-collector:4317",
    "OtlpProtocol": "Grpc",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogs": false,
    "EnableConsoleLog": true,
    "EnableSeqLog": true,
    "SeqServerUrl": "http://seq",
    "ExposePrometheusEndpoint": true,
    "TraceSamplingRatio": 1.0
  },
  "AllowedHosts": "*",
  "App": {
    "Redis": {
      "RedisCacheConnection": "redis:6379,redis-replica:6379,abortConnect=false,connectRetry=3",
      "RedisCachePrefix": "finbot"
    }
  },
  "Kafka": {
    "BankGroupId": "bank-service-group"
  }
}
