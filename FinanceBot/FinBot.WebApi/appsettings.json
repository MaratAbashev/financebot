{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Observability": {
    "ServiceName": "finbot.webapi",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://otel-collector:4317",
    "OtlpProtocol": "Grpc",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogs": false,
    "EnableConsoleLog": true,
    "EnableSeqLog": true,
    "SeqServerUrl": "http://seq",
    "ExposePrometheusEndpoint": true,
    "TraceSamplingRatio": 1.0
  },
  "App": {
    "Redis": {
      "RedisCacheConnection": "redis:6379,redis-replica:6379,abortConnect=false,connectRetry=3",
      "RedisCachePrefix": "library"
    },
    "App": "http://finbot.app:8080",
    "BankService": "http://finbot.bankservice:8080"
  },
  "AllowedHosts": "*",
  "Storage": {
    "ExcelTablesBucket": "excel-tables",
    "BarChartsBucket": "bar-charts",
    "LineChartsBucket": "line-charts"
  },
  "MinioOptions": {
    "Endpoint": "localhost:9000",
    "AccessKey": "minioadmin",
    "SecretKey": "minioadmin"
  },
  "Kafka": {
    "BootstrapServers": "kafka-1:9092,kafka-2:9092",
    "LlmApiGroupId": "llm-api-group",
    "ExcelApiGroupId": "excel-api-group"
  }
}