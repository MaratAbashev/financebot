{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/banking-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Username=postgres;Password=postgres;Database=banking_db"
  },
  "Jwt": {
    "Secret": "your-very-long-secret-key-min-32-chars",
    "Issuer": "BankingApi",
    "Audience": "BankingApiUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "VerificationCode": {
    "ExpiryMinutes": 5,
    "Length": 6
  },
  "OAuth": {
    "BaseUrl": "http://localhost:5152",
    "SessionExpiryMinutes": 10
  }
}
