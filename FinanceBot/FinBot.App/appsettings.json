{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "Observability": {
    "ServiceName": "finbot.app",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://otel-collector:4317",
    "OtlpProtocol": "Grpc",
    "EnableTracing": true,
    "EnableMetrics": true,
    "EnableLogs": false,
    "EnableConsoleLog": true,
    "EnableSeqLog": true,
    "SeqServerUrl": "http://seq",
    "ExposePrometheusEndpoint": true,
    "TraceSamplingRatio": 1.0
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PDbContext": "Host=localhost;Port=5432;Database=financebot;Username=postgres;Password=postgres"
  }
}

